<?xml version="1.0" ?>
<sdf version="1.10">
  <model name="ucsd_drone">
    <static>false</static>
    <pose>0 0 0 0 0 0</pose>

    <link name="base_link">
      <inertial>
        <mass>1.4</mass>
        <inertia>
          <ixx>0.03</ixx>
          <iyy>0.03</iyy>
          <izz>0.05</izz>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyz>0</iyz>
        </inertia>
      </inertial>

      <collision name="body_collision">
        <geometry>
          <box>
            <size>0.4 0.4 0.1</size>
          </box>
        </geometry>
      </collision>

      <visual name="body_visual">
        <geometry>
          <box>
            <size>0.4 0.4 0.1</size>
          </box>
        </geometry>
        <material>
          <ambient>0.15 0.15 0.17 1</ambient>
          <diffuse>0.2 0.2 0.25 1</diffuse>
          <specular>0.3 0.3 0.3 1</specular>
        </material>
      </visual>

      <visual name="arm_front">
        <pose>0.18 0 0 0 1.5708 0</pose>
        <geometry><cylinder><radius>0.015</radius><length>0.42</length></cylinder></geometry>
      </visual>
      <visual name="arm_left">
        <pose>0 0.18 0 1.5708 1.5708 0</pose>
        <geometry><cylinder><radius>0.015</radius><length>0.42</length></cylinder></geometry>
      </visual>

      <visual name="rotor_fl">
        <pose>0.2 0.2 0.05 0 0 0</pose>
        <geometry><sphere><radius>0.06</radius></sphere></geometry>
        <material><ambient>0.05 0.05 0.05 1</ambient><diffuse>0.1 0.1 0.1 1</diffuse></material>
      </visual>
      <visual name="rotor_fr">
        <pose>0.2 -0.2 0.05 0 0 0</pose>
        <geometry><sphere><radius>0.06</radius></sphere></geometry>
        <material><ambient>0.05 0.05 0.05 1</ambient><diffuse>0.1 0.1 0.1 1</diffuse></material>
      </visual>
      <visual name="rotor_rl">
        <pose>-0.2 0.2 0.05 0 0 0</pose>
        <geometry><sphere><radius>0.06</radius></sphere></geometry>
        <material><ambient>0.05 0.05 0.05 1</ambient><diffuse>0.1 0.1 0.1 1</diffuse></material>
      </visual>
      <visual name="rotor_rr">
        <pose>-0.2 -0.2 0.05 0 0 0</pose>
        <geometry><sphere><radius>0.06</radius></sphere></geometry>
        <material><ambient>0.05 0.05 0.05 1</ambient><diffuse>0.1 0.1 0.1 1</diffuse></material>
      </visual>

      <sensor name="drone_cam" type="camera">
        <pose>0 0 -0.06 0 -1.5708 0</pose>
        <update_rate>30</update_rate>
        <always_on>true</always_on>
        <camera>
          <horizontal_fov>1.047</horizontal_fov>
          <image>
            <width>640</width>
            <height>480</height>
            <format>R8G8B8</format>
          </image>
          <clip>
            <near>0.5</near>
            <far>200</far>
          </clip>
        </camera>
        <topic>/drone/camera</topic>
        <visualize>true</visualize>
      </sensor>
    </link>
  </model>
</sdf>
