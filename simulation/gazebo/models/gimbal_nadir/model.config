<?xml version="1.0"?>
<model>
  <name>gimbal_nadir</name>
  <version>1.0</version>
  <sdf version="1.9">model.sdf</sdf>
  <author>
    <name>robotx-navigation</name>
  </author>
  <description>
    Fixed nadir (straight-down) camera pod for the RobotX UAV course.
    Carries a single calibration-matched camera sensor (1920x1080,
    fx/fy/cx/cy from calibration/camera_intrinsics_latest.json) publishing
    to /drone/camera. Not actuated: unlike gimbal_small_3d there are no
    roll/pitch/yaw joints; the camera is rigidly down-pointing so the
    ground/GPS projection in camera_live_feed.py (nadir, image +x->East,
    +y->South) holds without gimbal state.
  </description>
</model>
