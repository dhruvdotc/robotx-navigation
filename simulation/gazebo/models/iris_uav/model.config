<?xml version="1.0"?>
<model>
  <name>iris_uav</name>
  <version>1.0</version>
  <sdf version="1.9">model.sdf</sdf>
  <author>
    <name>robotx-navigation</name>
  </author>
  <description>
    RobotX UAV: stock ardupilot_gazebo iris_with_standoffs airframe
    (rotors + IMU + ArduPilotPlugin FDM, UDP 9002, lock_step) with the
    fixed nadir camera pod (gimbal_nadir) rigidly mounted underneath instead
    of the actuated gimbal_small_3d. Replaces the stock iris_with_gimbal in
    robotx_uav_course.sdf so the down-facing, calibration-matched camera on
    /drone/camera is available for ground/GPS projection.
    Requires both this repo's models dir and ardupilot_gazebo/models on
    GZ_SIM_RESOURCE_PATH (iris_with_standoffs lives in ardupilot_gazebo).
  </description>
</model>
